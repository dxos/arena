  "scripts": {
    "build": "mkdir -p dist && cp -r src/assets dist/ && babel src -d dist",
    "build:dev": "mkdir -p dist && cp -r src/assets dist/ && babel src -d dist --watch",
    "debug": "DOT_ENV=.env.debug webpack-dev-server --mode development",
    "debug:localhost": "CONFIG=localhost.yml webpack-dev-server --mode development",
    "dist": "rollup -c",
    "lint": "eslint 'src/**/*.{js,jsx,ts,tsx}'",
    "storybook": "start-storybook -s ./stories/static -p 9001 -c .storybook --ci",
    "test": "jest --rootDir ./src --verbose --passWithNoTests"
  },
