{
  "name": "@dxos/game-cli",
  "version": "1.2.0-alpha.14",
  "license": "GPL-3.0",
  "main": "dist/es/index.js",
  "private": true,
  "bin": {
    "wire-game": "bin/wire-game.js"
  },
  "files": [
    "bin/",
    "dist/es"
  ],
  "scripts": {
    "build": "babel ./src --out-dir ./dist/es --ignore \"**/*.test.js\" --copy-files",
    "clean": "rm -rf ./dist",
    "cli": "BABEL_CACHE_PATH=./dist/babel-cache.json babel-node ./src/index.js",
    "lint": "eslint '**/*.js' --ignore-path ../../.eslintignore",
    "prepublishOnly": "npm run clean && npm run build && npm run test",
    "test": "jest --rootDir ./src --verbose --passWithNoTests"
  },
  "jest": {
    "cacheDirectory": "/tmp/jest",
    "verbose": false
  },
  "dependencies": {
    "@babel/runtime": "7.11.2",
    "@dxos/async": "1.0.2-alpha.0",
    "@dxos/cli-core": "^2.0.4-alpha.0",
    "@dxos/crypto": "1.0.5",
    "@dxos/debug": "^1.0.0-beta.73",
    "@dxos/game-model": "^1.2.0-alpha.14",
    "assert": "^2.0.0",
    "chance": "^1.1.3",
    "command-exists": "^1.2.9",
    "hypercore-crypto": "^1.0.0",
    "read-pkg-up": "^6.0.0",
    "yargs": "^11.0.0"
  },
  "devDependencies": {
    "@babel/cli": "^7.8.4",
    "@babel/core": "^7.9.0",
    "@babel/node": "^7.8.7",
    "@babel/plugin-proposal-class-properties": "^7.10.1",
    "@babel/plugin-transform-runtime": "^7.10.1",
    "@babel/preset-env": "^7.10.2",
    "@dxos/eslint-plugin": "^1.0.8",
    "babel-jest": "^25.1.0",
    "babel-loader": "^8.1.0",
    "babel-plugin-add-module-exports": "^1.0.2",
    "babel-plugin-inline-import": "^3.0.0",
    "eslint": "^7.11.0",
    "jest": "^26.6.1",
    "prettier": "^1.14.2",
    "typescript": "^4.0.5",
    "uuid": "^7.0.3"
  },
  "eslintConfig": {
    "extends": "plugin:@dxos/recomended"
  },
  "peerDependencies": {
    "@dxos/cli": "^2.0.4-alpha.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
